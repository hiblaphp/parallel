{
    "name": "hiblaphp/parallel",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Hibla\\Parallel\\": "src/"
        },
        "files": [
            "src/functions.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        },
        "files": [
            "tests/Fixtures/callable_functions.php"
        ]
    },
    "prefer-stable": true,
    "minimum-stability": "alpha",
    "require": {
        "php": "^8.4",
        "rcalicdan/config-loader": "^1.0",
        "rcalicdan/serializer": "^1.0",
        "hiblaphp/event-loop": "^1.0",
        "hiblaphp/promise": "^1.0",
        "hiblaphp/cancellation": "^1.0",
        "hiblaphp/async": "^1.0",
        "hiblaphp/stream": "^1.0"
    },
    "require-dev": {
        "pestphp/pest": "^4.0",
        "phpstan/phpstan": "^2.1",
        "phpstan/phpstan-strict-rules": "^2.0",
        "laravel/pint": "^1.25",
        "mockery/mockery": "^1.6",
        "phpstan/extension-installer": "^1.4",
        "hiblaphp/socket": "^1.0"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "scripts": {
        "test": "vendor/bin/pest",
        "analyze": "vendor/bin/phpstan analyse",
        "format": "vendor/bin/pint"
    }
}